# TinaCMS Cloud — fill these in once the Tina project is created (deploy step 5).
# Leave empty for local editing (`npm run dev:cms` → http://localhost:3000/admin).
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
# Branch Tina edits against. On Vercel this is set automatically per deploy.
NEXT_PUBLIC_TINA_BRANCH=main
