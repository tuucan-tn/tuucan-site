# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# tinacms built admin SPA output (large, rebuilt on each deploy — not committed)
/public/admin
# NOTE: tina/__generated__ IS committed on purpose — TinaCloud reads the schema
# (_graphql.json/_lookup.json/_schema.json) from the repo to index content.

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
